g,\n53\t    };\n54\t    res.json(resp);\n55\t    return;\n56\t  }\n57\t\n58\t  const dispatchReq: DispatchRequest = {\n59\t    taskId,\n60\t    projectId,\n61\t    componentName,\n62\t    prompt,\n63\t    mcpEndpointUrl,\n64\t    orgId: body.orgId,\n65\t    workspacePath: body.workspacePath,\n66\t  };\n67\t\n68\t  const startedAt = new Date();\n69\t  let started;\n70\t  try {\n71\t    const log = openTaskLog(workspacePath);\n72\t    started = runClaudeQuery(dispatchReq, workspacePath, log);\n73\t  } catch (err) {\n74\t    const msg = err instanceof Error ? err.message : String(err);\n75\t    console.error(\"failed to start claude query\", {\n76\t      taskId,\n77\t      component: componentName,\n78\t      error: msg,\n79\t    });\n80\t    const resp: DispatchResponse = {\n81\t      taskId,\n82\t      workspacePath,\n83\t      status: \"failed\",\n84\t      error: \"failed to start claude query: \" + msg,\n85\t    };\n86\t    res.json(resp);\n87\t    return;\n88\t  }\n89\t\n90\t  taskRegistry.set(taskId, {\n91\t    taskId,\n92\t    componentName,\n93\t    workspacePath,\n94\t    startedAt,\n95\t    query: started.query,\n96\t    done: false,\n97\t    exitCode: 0,\n98\t  });\n99\t\n100\t  console.log(\"dispatched task\", {\n101\t    taskId,\n102\t    component: componentName,\n103\t    workspace: workspacePath,\n104\t  });\n105\t\n106\t  started.completion.then((result) => {\n107\t    taskRegistry.markDone(taskId, result.exitCode, result.error);\n108\t    const duration = Date.now() - startedAt.getTime();\n109\t    if (result.exitCode === 0) {\n110\t      console.log(\"claude query completed\", {\n111\t        taskId,\n112\t        component: componentName,\n113\t        durationMs: duration,\n114\t      });\n115\t    } else {\n116\t      console.error(\"claude query failed\", {\n117\t        taskId,\n118\t        component: componentName,\n119\t        exitCode: result.exitCode,\n120\t        error: result.error,\n121\t        durationMs: duration,\n122\t      });\n123\t    }\n124\t  });\n125\t\n126\t  const resp: DispatchResponse = {\n127\t    taskId,\n128\t    workspacePath,\n129\t    status: \"running\",\n130\t  };\n131\t  res.json(resp);\n132\t});\n133\t\n134\texport default router;\n135\t"}]},"parent_tool_use_id":null,"session_id":"121c440b-f753-45aa-a34f-20b71a71ccd0","uuid":"58a49a68-76c0-4731-96fd-fdfa4a85cf65","timestamp":"2026-04-24T02:11:58.312Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/wso2/repos/asdlc/local-dispatcher/src/routes/dispatch.ts","content":"import { Router } from \"express\";\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport { config } from \"../config.js\";\nimport { openTaskLog } from \"../lib/logger.js\";\nimport { runClaudeQuery } from \"../lib/runner.js\";\nimport * as taskRegistry from \"../lib/taskRegistry.js\";\nimport type { DispatchRequest, DispatchResponse } from \"../lib/types.js\";\n\nconst router = Router();\n\nrouter.post(\"/dispatch\", (req, res) => {\n  const body = (req.body ?? {}) as Partial<DispatchRequest>;\n  const { taskId, projectId, componentName, prompt, mcpEndpointUrl } = body;\n  if (!taskId || !projectId || !componentName || !prompt || !mcpEndpointUrl) {\n    res.status(400).json({\n      error:\n        \"taskId, projectId, componentName, prompt, and mcpEndpointUrl are required\",\n    });\n    return;\n  }\n\n  const existing = taskRegistry.get(taskId);\n  if (existing && !existing.done) {\n    const resp: DispatchResponse = {\n      taskId,\n      workspacePath: existing.workspacePath,\n      status: \"running\",\n    };\n    res.json(resp);\n    return;\n  }\n\n  const workspacePath =\n    body.workspacePath ||\n    path.join(\n      config.workspaceBasePath,\n      body.orgId || \"\",\n      projectId,\n      componentName,\n    );\n\n  try {\n    fs.mkdirSync(workspacePath, { recursive: true, mode: 0o755 });\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.error(\"failed to create workspace\", { workspacePath, error: msg });\n    const resp: DispatchResponse = {\n      taskId,\n      workspacePath,\n      status: \"failed\",\n      error: \"failed to create workspace: \" + msg,\n    };\n    res.json(resp);\n    return;\n  }\n\n  const dispatchReq: DispatchRequest = {\n    taskId,\n    projectId,\n    componentName,\n    prompt,\n    mcpEndpointUrl,\n    orgId: body.orgId,\n    workspacePath: body.workspacePath,\n  };\n\n  const startedAt = new Date();\n  let started;\n  try {\n    const log = openTaskLog(workspacePath);\n    started = runClaudeQuery(dispatchReq, workspacePath, log);\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.error(\"failed to start claude query\", {\n      taskId,\n      component: componentName,\n      error: msg,\n    });\n    const resp: DispatchResponse = {\n      taskId,\n      workspacePath,\n      status: \"failed\",\n      error: \"failed to start claude query: \" + msg,\n    };\n    res.json(resp);\n    return;\n  }\n\n  taskRegistry.set(taskId, {\n    taskId,\n    componentName,\n    workspacePath,\n    startedAt,\n    query: started.query,\n    done: false,\n    exitCode: 0,\n  });\n\n  console.log(\"dispatched task\", {\n    taskId,\n    component: componentName,\n    workspace: workspacePath,\n  });\n\n  started.completion.then((result) => {\n    taskRegistry.markDone(taskId, result.exitCode, result.error);\n    const duration = Date.now() - startedAt.getTime();\n    if (result.exitCode === 0) {\n      console.log(\"claude query completed\", {\n        taskId,\n        component: componentName,\n        durationMs: duration,\n      });\n    } else {\n      console.error(\"claude query failed\", {\n        taskId,\n        component: componentName,\n        exitCode: result.exitCode,\n        error: result.error,\n        durationMs: duration,\n      });\n    }\n  });\n\n  const resp: DispatchResponse = {\n    taskId,\n    workspacePath,\n    status: \"running\",\n  };\n  res.json(resp);\n});\n\nexport default router;\n","numLines":135,"startLine":1,"totalLines":135}}}
