ck, Casual]\\n      responses:\\n        '201':\\n          description: Request created\\n          content:\\n            application/json:\\n              schema:\\n                $ref: '#/components/schemas/LeaveRequest'\\n        '400':\\n          description: Invalid input\\n  /requests/{id}:\\n    patch:\\n      summary: Approve or reject a leave request\\n      parameters:\\n        - name: id\\n          in: path\\n          required: true\\n          schema:\\n            type: string\\n      requestBody:\\n        required: true\\n        content:\\n          application/json:\\n            schema:\\n              type: object\\n              required: [status, managerId]\\n              properties:\\n                status:\\n                  type: string\\n                  enum: [approved, rejected]\\n                managerId:\\n                  type: string\\n                comment:\\n                  type: string\\n      responses:\\n        '200':\\n          description: Request updated\\n          content:\\n            application/json:\\n              schema:\\n                $ref: '#/components/schemas/LeaveRequest'\\n        '404':\\n          description: Request not found\\n        '400':\\n          description: Invalid input\\n  /balance:\\n    get:\\n      summary: Get leave balance for a user\\n      parameters:\\n        - name: employeeId\\n          in: query\\n          required: true\\n          schema:\\n            type: string\\n      responses:\\n        '200':\\n          description: Leave balance by type\\n          content:\\n            application/json:\\n              schema:\\n                type: object\\n                properties:\\n                  employeeId:\\n                    type: string\\n                  balances:\\n                    type: object\\n                    additionalProperties:\\n                      type: number\\n                    example:\\n                      Annual: 15\\n  